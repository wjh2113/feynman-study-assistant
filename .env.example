DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_MODEL=deepseek-v4-pro
PORT=8787

# 支持图片输入的 OpenAI 兼容视觉模型，用于 OCR
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY=
VISION_MODEL=qwen3.5-ocr

# 留空时使用项目内置的可落盘 PostgreSQL（PGlite + pgvector）
# 部署到标准 PostgreSQL 时填写，例如：
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zhifan
DATABASE_URL=
DATABASE_SSL=false
DATA_DIR=.data

# 检索模型：默认使用阿里云百炼云端 Embedding/Reranker
# 配置后不会再启动本地 Python BGE 服务，可删除 .data/models 和 .tools/python311
EMBEDDING_PROVIDER=remote
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

RERANKER_PROVIDER=remote
RERANKER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANKER_API_KEY=
RERANKER_MODEL=gte-rerank

RAG_RELEVANCE_THRESHOLD=0.35
BGE_AUTO_START=false

# 生产环境必须配置浏览器实际访问来源，多个来源用逗号分隔
# ALLOWED_ORIGINS=https://study.example.com
# 仅在应用位于可信反向代理之后设置，例如 TRUST_PROXY=loopback
# TRUST_PROXY=

# 其他可选云端 Embedding/Reranker 示例
# SiliconFlow: EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
#              EMBEDDING_MODEL=BAAI/bge-m3
#              RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# OpenAI:      EMBEDDING_BASE_URL=https://api.openai.com/v1
#              EMBEDDING_MODEL=text-embedding-3-large
#              RERANKER_BASE_URL=https://api.openai.com/v1
