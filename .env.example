DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
PORT=8787

# 支持图片输入的 OpenAI 兼容视觉模型，用于 OCR
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_API_KEY=
VISION_MODEL=qwen3.5-ocr

# 留空时使用项目内置的可落盘 PostgreSQL（PGlite + pgvector）
# 部署到标准 PostgreSQL 时填写，例如：
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zhifan
DATABASE_URL=
DATABASE_SSL=false
DATA_DIR=.data
REDIS_URL=redis://127.0.0.1:6379

# 生产环境必须设置为至少 32 字节随机值；用于 AES-256-GCM 加密模型密钥
APP_ENCRYPTION_KEY=

# 文件存储：local 或 oss
STORAGE_PROVIDER=local
OSS_REGION=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# 邮件与提醒
PUBLIC_BASE_URL=http://127.0.0.1:8787
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 支付；无商户凭据时使用 sandbox
PAYMENT_PROVIDER=sandbox
PAYMENT_SANDBOX=true
PAYMENT_WEBHOOK_SECRET=
WECHATPAY_MCH_ID=
WECHATPAY_PRIVATE_KEY=
WECHATPAY_PLATFORM_CERT=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 模型超时与慢请求阈值
RETRIEVAL_TIMEOUT_MS=30000
GENERATION_TIMEOUT_MS=45000
SLOW_REQUEST_MS=5000

# 检索模型：默认使用阿里云百炼云端 Embedding/Reranker
# 配置后不会再启动本地 Python BGE 服务，可删除 .data/models 和 .tools/python311
EMBEDDING_PROVIDER=remote
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

RERANKER_PROVIDER=remote
RERANKER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANKER_API_KEY=
RERANKER_MODEL=gte-rerank

RAG_RELEVANCE_THRESHOLD=0.35
BGE_AUTO_START=false

# 生产环境必须配置浏览器实际访问来源，多个来源用逗号分隔
# ALLOWED_ORIGINS=https://study.example.com
# 仅在应用位于可信反向代理之后设置，例如 TRUST_PROXY=loopback
# TRUST_PROXY=

# 其他可选云端 Embedding/Reranker 示例
# SiliconFlow: EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
#              EMBEDDING_MODEL=BAAI/bge-m3
#              RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# OpenAI:      EMBEDDING_BASE_URL=https://api.openai.com/v1
#              EMBEDDING_MODEL=text-embedding-3-large
#              RERANKER_BASE_URL=https://api.openai.com/v1
