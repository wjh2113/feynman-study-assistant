DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_MODEL=deepseek-v4-pro
PORT=8787

# 支持图片输入的 OpenAI 兼容视觉模型，用于 OCR
VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=
VISION_MODEL=gpt-4.1-mini

# 留空时使用项目内置的可落盘 PostgreSQL（PGlite + pgvector）
# 部署到标准 PostgreSQL 时填写，例如：
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zhifan
DATABASE_URL=
DATABASE_SSL=false
DATA_DIR=.data

# 本地 BGE 模型服务；应用会尝试从项目 .tools/python311 自动启动
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
RERANKER_BASE_URL=http://127.0.0.1:8001/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RELEVANCE_THRESHOLD=0.35
BGE_AUTO_START=true
